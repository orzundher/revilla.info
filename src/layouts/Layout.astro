---
interface Props {
	title?: string;
	description?: string;
	fullscreen?: boolean;
}
const { title = 'Revilla — Portfolio de Desarrollo Web y Cartografía', description = 'Revilla — Portfolio personal de desarrollo web, cartografía, visualización de datos y proyectos creativos con tecnologías modernas.', fullscreen = false } = Astro.props;
const normalizePath = (path: string) => (path !== '/' && path.endsWith('/') ? path.slice(0, -1) : path);
const currentPath = normalizePath(Astro.url.pathname);
const isActive = (href: string) => currentPath === href || currentPath.startsWith(`${href}/`);
const navLinks = [
	{ href: '/info',    label: 'Info' },
	{ href: '/skills',  label: 'Skills' },
	{ href: '/works',   label: 'Works' },
	{ href: '/posts',   label: 'Posts' },
	{ href: '/map',          label: 'Map' },
	{ href: '/pointclouds',  label: 'Point Clouds' },
	{ href: '/contact',      label: 'Contact' },
];
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="canonical" href={Astro.url.href} />
		<meta property="og:url" content={Astro.url.href} />
		<meta property="og:title" content={title} />
		<meta property="og:site_name" content="Revilla" />
		<meta property="og:locale" content="en_US" />
		<meta property="og:image" content="https://revilla.info/og-image.jpg" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="Revilla — Portfolio de Desarrollo Web y Cartografía" />
		<meta name="twitter:card" content="summary_large_image" />
		<title>{title}</title>
	</head>
	<body>
		<header class="header">
			<nav class="nav">
				<a href="/" class:list={["logo", { active: currentPath === '/' }]}>Revilla</a>
				<ul class="nav-links">
					{navLinks.map(({ href, label }) => (
						<li><a href={href} class:list={[{ active: isActive(href) }]}>{label}</a></li>
					))}
				</ul>
				<button class="hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
					<span class="hamburger-line"></span>
					<span class="hamburger-line"></span>
					<span class="hamburger-line"></span>
				</button>
			</nav>
		</header>

		<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
			<ul class="mobile-nav-links">
				{navLinks.map(({ href, label }) => (
					<li><a href={href} class:list={[{ active: isActive(href) }]}>{label}</a></li>
				))}
			</ul>
		</div>

		<main class:list={['page-content', { 'page-content--fullscreen': fullscreen }]}>
			<slot />
		</main>

		{!fullscreen && (
		<footer class="footer">
			<p>&copy; 2025 Revilla.</p>
		</footer>
	)}

		<script>
			(function () {
				var header = document.querySelector('.header') as HTMLElement | null;
				var btn = document.querySelector('.hamburger') as HTMLElement | null;
				var overlay = document.getElementById('mobile-menu');
				if (!btn || !overlay || !header) return;
				var h = header, b = btn, o = overlay;

				function openMenu() {
					h.classList.add('menu-open');
					document.body.style.overflow = 'hidden';
					b.setAttribute('aria-expanded', 'true');
					o.setAttribute('aria-hidden', 'false');
				}
				function closeMenu() {
					h.classList.remove('menu-open');
					document.body.style.overflow = '';
					b.setAttribute('aria-expanded', 'false');
					o.setAttribute('aria-hidden', 'true');
				}

				b.addEventListener('click', function () {
					h.classList.contains('menu-open') ? closeMenu() : openMenu();
				});
				o.addEventListener('click', function (e) {
					if (e.target === o) closeMenu();
				});
				document.addEventListener('keydown', function (e) {
					if (e.key === 'Escape' && h.classList.contains('menu-open')) {
						closeMenu(); b.focus();
					}
				});
				o.querySelectorAll('a').forEach(function (a) {
					a.addEventListener('click', closeMenu);
				});
				window.addEventListener('resize', function () {
					if (window.innerWidth > 1024 && h.classList.contains('menu-open')) closeMenu();
				});
			})();
		</script>
	</body>
</html>

<style>
	:root {
		--color-primary: #6366f1;
		--color-bg: #0f172a;
		--color-bg-alt: #1e293b;
		--color-text: #e2e8f0;
		--color-text-muted: #94a3b8;
		--color-border: #334155;
		--spacing-xs: 0.5rem;
		--spacing-sm: 1rem;
		--spacing-md: 2rem;
		--spacing-lg: 4rem;
		--spacing-xl: 6rem;
	}

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
		scrollbar-width: none;
		-ms-overflow-style: none;
	}

	html::-webkit-scrollbar,
	body::-webkit-scrollbar {
		display: none;
	}

	body {
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen',
			'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
		background-color: var(--color-bg);
		color: var(--color-text);
		line-height: 1.6;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	/* ── Nav ── */
	.header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		background-color: rgba(217, 119, 6, 0.15);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
	}

	.nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.5rem 2.5rem;
	}

	.logo {
		font-size: 1rem;
		font-weight: 600;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-text);
		text-decoration: none;
	}

	.nav-links {
		display: flex;
		gap: 2rem;
		list-style: none;
	}

	.nav-links a {
		font-size: 0.8rem;
		font-weight: 500;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-text);
		text-decoration: none;
		opacity: 0.5;
		transition: opacity 0.2s ease;
	}

	.nav-links a:hover,
	.nav-links a.active {
		opacity: 1;
	}

	/* ── Hamburger button ── */
	.hamburger {
		display: none;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		gap: 5px;
		width: 44px;
		height: 44px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0;
		z-index: 110;
	}

	.hamburger-line {
		display: block;
		width: 22px;
		height: 2px;
		background-color: var(--color-text);
		border-radius: 2px;
		transition: transform 0.25s ease, opacity 0.25s ease;
		transform-origin: center;
	}

	/* Hamburger → X when menu is open */
	.header.menu-open .hamburger-line:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}
	.header.menu-open .hamburger-line:nth-child(2) {
		opacity: 0;
		transform: scaleX(0);
	}
	.header.menu-open .hamburger-line:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}

	/* ── Mobile overlay ── */
	.mobile-menu {
		display: none;
		position: fixed;
		inset: 0;
		background-color: rgba(217, 119, 6, 0.15);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		flex-direction: column;
		justify-content: center;
		align-items: center;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.25s ease;
		z-index: 105;
	}

	.header.menu-open ~ .mobile-menu {
		opacity: 1;
		pointer-events: auto;
	}

	.mobile-nav-links {
		list-style: none;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
	}

	.mobile-nav-links a {
		display: block;
		padding: 0.875rem 2rem;
		font-size: 1.25rem;
		font-weight: 500;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-text);
		text-decoration: none;
		opacity: 0.5;
		transition: opacity 0.2s ease;
	}

	.mobile-nav-links a:hover,
	.mobile-nav-links a.active {
		opacity: 1;
	}

	/* ── Page content ── */
	.page-content {
		flex: 1;
		padding-top: 4rem;
	}

	.page-content--fullscreen {
		padding-top: 0;
		flex: 1;
		position: relative;
	}

	/* ── Footer ── */
	.footer {
		padding: 2rem 2.5rem;
		color: var(--color-text-muted);
		font-size: 0.8rem;
		border-top: 1px solid var(--color-border);
	}

	/* ── Breakpoints ── */
	@media (min-width: 1280px) {
		.nav {
			padding: 1.5rem 4rem;
		}
		.footer {
			padding: 2rem 4rem;
		}
	}

	@media (max-width: 1024px) {
		.nav-links {
			display: none;
		}

		.hamburger {
			display: flex;
		}

		.mobile-menu {
			display: flex;
		}
	}

	@media (max-width: 768px) {
		.nav {
			padding: 1.25rem 1.5rem;
		}
	}

	@media (max-width: 480px) {
		.nav {
			padding: 1rem 1.25rem;
		}

		.mobile-nav-links a {
			font-size: 1.1rem;
		}
	}
</style>
