---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Ponte en Contacto | Revilla">
	<section class="page">
		<div class="container">
			<h1 class="page-title">Contact</h1>
			<p class="page-text">Do you have a project in mind? I would love to hear from you.</p>
			<ul class="contact-list">
				<li>
					<a href="mailto:orzundher@email.com" class="contact-link">Email</a>
				</li>
				<li>
					<a href="https://github.com/orzundher" class="contact-link" target="_blank" rel="noopener">GitHub</a>
				</li>
				<li>
					<a href="https://linkedin.com/in/orzundher" class="contact-link" target="_blank" rel="noopener">LinkedIn</a>
				</li>
				<li>
					<a href="https://twitter.com/orzundher" class="contact-link" target="_blank" rel="noopener">Twitter</a>
				</li>
			</ul>
		</div>
	</section>
</Layout>

<style>
	.page {
		padding: 0.75rem 2.5rem 4rem;
	}

	.container {
		max-width: 720px;
	}

	.page-title {
		font-size: clamp(2rem, 5vw, 3rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-bottom: 1.5rem;
	}

	.page-text {
		font-size: 1.125rem;
		color: #94a3b8;
		margin-bottom: 2.5rem;
	}

	.contact-list {
		list-style: none;
		border-top: 1px solid #334155;
	}

	.contact-link {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.25rem 0;
		border-bottom: 1px solid #334155;
		text-decoration: none;
		font-size: 1rem;
		color: #e2e8f0;
		opacity: 0.7;
		transition: opacity 0.2s ease;
	}

	.contact-link::after {
		content: '→';
		opacity: 0.4;
		transition: opacity 0.2s ease, transform 0.2s ease;
	}

	.contact-link:hover {
		opacity: 1;
	}

	.contact-link:hover::after {
		opacity: 1;
		transform: translateX(4px);
	}
</style>
