---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Info — Revilla">
	<section class="page">
		<div class="container">
			<h1 class="page-title">Info</h1>
			<p class="page-text">
				Soy un desarrollador apasionado por crear soluciones web elegantes y eficientes.
				Me especializo en tecnologías modernas y siempre estoy aprendiendo algo nuevo.
			</p>
		</div>
	</section>
</Layout>

<style>
	.page {
		padding: 4rem 2.5rem;
	}

	.container {
		max-width: 720px;
	}

	.page-title {
		font-size: clamp(2rem, 5vw, 3rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-bottom: 1.5rem;
	}

	.page-text {
		font-size: 1.125rem;
		color: #94a3b8;
		line-height: 1.8;
		max-width: 600px;
	}
</style>
