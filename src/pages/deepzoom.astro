---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Deepzoom — Revilla" fullscreen={true}>
	<div id="osd-viewer"></div>
</Layout>

<style>
	#osd-viewer {
		position: fixed;
		inset: 0;
		width: 100%;
		height: 100%;
		background: #0f172a;
	}
</style>

<script>
	import OpenSeadragon from 'openseadragon';

	OpenSeadragon({
		id: 'osd-viewer',
		prefixUrl: '',
		tileSources: '/assets/realny_tiles.dzi',
		showNavigationControl: false,
		visibilityRatio: 1,
		minZoomLevel: 1,
		defaultZoomLevel: 1,
	});
</script>
