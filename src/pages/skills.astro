---
import Layout from '../layouts/Layout.astro';

const categories = [
	{
		title: 'Languajes',
		items: [
			{ name: 'C#', level: 6 },
			{ name: 'JavaScript', level: 6 },
			{ name: 'TypeScript', level: 5 },
			{ name: 'Go', level: 3 },
			{ name: 'Java', level: 3 },
			{ name: 'Kotlin', level: 2 },
		]
	},
	{
		title: 'DevOps & Containers',
		items: [
			{ name: 'Docker', level: 6 },
			{ name: 'Kubernetes', level: 5 },
		]
	},
	{
		title: 'Cloud',
		items: [
			{ name: 'Microsoft Azure', level: 5 },
		]
	},
	{
		title: 'Backend',
		items: [
			{ name: 'Node.js', level: 6 },
			{ name: '.NET / ASP.NET Core', level: 6 },
			{ name: 'Entity Framework Core', level: 5 },
			{ name: '.NET Aspire', level: 3 },
		]
	},
	{
		title: 'Web & Frameworks',
		items: [
			{ name: 'React', level: 5 },
			{ name: 'CSS / SCSS', level: 4 },
			{ name: 'Astro', level: 3 },
		]
	}
];
---

<Layout title="Skills — Revilla">
	<section class="page">
		<div class="container">
			<h1 class="page-title">Skills</h1>
			
			{categories.map((category) => (
				<div class="category-section">
					<h2 class="category-title">{category.title}</h2>
					<ul class="skills-list">
						{category.items.map((skill) => (
							<li class="skill-item">
								<span class="skill-name">{skill.name}</span>
								<span class="skill-bar" aria-label={`Level ${skill.level} of 6`}>
									{[1,2,3,4,5,6].map((step) => (
										<span class={`skill-step ${step <= skill.level ? 'filled' : ''}`}></span>
									))}
								</span>
							</li>
						))}
					</ul>
				</div>
			))}
		</div>
	</section>
</Layout>

<style>
	.page {
		padding: 4rem 2.5rem;
	}

	.container {
		max-width: 720px;
	}

	.page-title {
		font-size: clamp(2rem, 5vw, 3rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-bottom: 2.5rem;
	}

	.category-section {
		margin-bottom: 3rem;
	}

	.category-title {
		font-size: 1.25rem;
		font-weight: 600;
		color: #94a3b8;
		margin-bottom: 1rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	.skills-list {
		list-style: none;
		border-top: 1px solid #334155;
	}

	.skill-item {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 0;
		border-bottom: 1px solid #334155;
		font-size: 1.125rem;
		color: #e2e8f0;
	}

	.skill-name {
		flex: 1;
	}

	.skill-bar {
		display: flex;
		gap: 5px;
	}

	.skill-step {
		width: 18px;
		height: 8px;
		border-radius: 2px;
		background-color: #1e293b;
		border: 1px solid #334155;
	}

	.skill-step.filled {
		background-color: #38bdf8;
		border-color: #38bdf8;
	}
</style>
