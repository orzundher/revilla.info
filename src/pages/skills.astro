---
import Layout from '../layouts/Layout.astro';

const categories = [
	{
		title: 'Programming Languages',
		items: [
			{ name: 'C#', level: 5 },
			{ name: 'JavaScript', level: 5 },
			{ name: 'TypeScript', level: 4 },
			{ name: 'Python', level: 3 },
			{ name: 'Go', level: 2 },
			{ name: 'Java', level: 4 },
			{ name: 'Kotlin', level: 2 },
		]
	},
	{
		title: 'DevOps & Orchestration',
		items: [
			{ name: 'Docker', level: 5 },
			{ name: 'Kubernetes', level: 4 },
			{ name: 'GitLab CI', level: 4 },
			{ name: 'Azure DevOps', level: 4 },
			{ name: 'Apache Airflow', level: 2 },
			{ name: 'Argo Workflows', level: 2 }
		]
	},
	{
		title: 'Cloud Platforms',
		items: [
			{ name: 'Microsoft Azure', level: 5 },
			{ name: 'AWS', level: 2 },
		]
	},
	{
		title: 'Backend Technologies',
		items: [
			{ name: 'Node.js', level: 5 },
			{ name: '.NET / ASP.NET Core', level: 5 },
			{ name: 'Entity Framework Core', level: 4 },
			{ name: '.NET Aspire', level: 3 },
		]
	},
	{
		title: 'Frontend Technologies',
		items: [
			{ name: 'React', level: 5 },
			{ name: 'Angular', level: 3 },
			{ name: 'Vite', level: 4 },
			{ name: 'CSS / SCSS', level: 4 },
			{ name: 'Astro', level: 3 },
			{ name: 'Svelte', level: 2 },
			{ name: 'SolidJS', level: 2 },
			{ name: 'Gin', level: 3 },
			{ name: 'PHP', level: 3 },
			{ name: '.Net Blazor', level: 3 },
			{ name: 'Zustand', level: 3 },
			{ name: 'Tailwind CSS', level: 2 },
			{ name: 'Bootstrap', level: 4 },
		]
	},
	{
		title: 'Databases and Data Technologies',
		items: [
			{ name: 'SQL Server', level: 4 },
			{ name: 'PostgreSQL', level: 6 },
			{ name: 'MongoDB', level: 4 },
			{ name: 'Redis', level: 2 },
			{ name: 'Cosmos DB', level: 3 },
			{ name: 'MySQL', level: 3 },
			{ name: 'SQLite', level: 4 },
			{ name: 'Elasticsearch', level: 2 },
			{ name: 'Neo4j', level: 1 },
			{ name: 'Amazon Athena', level: 2 }
		]
	},
];
---

<Layout title="Skills — Revilla">
	<section class="page">
		<div class="container">
			<h1 class="page-title">Skills</h1>
			
			{categories.map((category) => (
				<div class="category-section">
					<h2 class="category-title">{category.title}</h2>
					<ul class="skills-list">
						{category.items.map((skill) => (
							<li class="skill-item">
								<span class="skill-name">{skill.name}</span>
								<span class="skill-bar" aria-label={`Level ${skill.level} of 6`}>
									{[1,2,3,4,5,6].map((step) => (
										<span class={`skill-step ${step <= skill.level ? 'filled' : ''}`}></span>
									))}
								</span>
							</li>
						))}
					</ul>
				</div>
			))}
		</div>
	</section>
</Layout>

<style>
	.page {
		padding: 0.75rem 2.5rem 4rem;
	}

	.container {
		max-width: 720px;
	}

	.page-title {
		font-size: clamp(2rem, 5vw, 3rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-bottom: 2.5rem;
	}

	.category-section {
		margin-bottom: 3rem;
	}

	.category-title {
		font-size: 1.25rem;
		font-weight: 600;
		color: #94a3b8;
		margin-bottom: 1rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	.skills-list {
		list-style: none;
		border-top: 1px solid #334155;
	}

	.skill-item {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 0;
		border-bottom: 1px solid #334155;
		font-size: 1.125rem;
		color: #e2e8f0;
	}

	.skill-name {
		flex: 1;
	}

	.skill-bar {
		display: flex;
		gap: 5px;
	}

	.skill-step {
		width: 18px;
		height: 8px;
		border-radius: 2px;
		background-color: #1e293b;
		border: 1px solid #334155;
	}

	.skill-step.filled {
		background-color: #38bdf8;
		border-color: #38bdf8;
	}
</style>
