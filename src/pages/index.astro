---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Revilla — Portfolio de Desarrollo Web y Cartografía" fullscreen={true}>
	<h1 class="sr-only">Revilla — Portfolio Personal</h1>
	<div id="osd-viewer"></div>
</Layout>

<style>
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
	#osd-viewer {
		position: fixed;
		inset: 0;
		width: 100%;
		height: 100%;
		background: #0f172a;
	}
</style>

<script>
	import OpenSeadragon from 'openseadragon';

	// Aspect ratio conocido de la imagen (15360×9600)
	const IMG_ASPECT = 15360 / 9600; // 1.6

	function getCoverZoom() {
		const w = window.innerWidth;
		const h = window.innerHeight;
		const containerAspect = w / h;
		// zoom=1 en OSD → imagen llena el ancho.
		// Para cover: si el container es más alto/cuadrado que la imagen, escalar al alto.
		return Math.max(1, IMG_ASPECT / containerAspect);
	}

	const viewer = OpenSeadragon({
		id: 'osd-viewer',
		prefixUrl: '',
		tileSources: '/assets/realny_tiles_avif.dzi',
		showNavigationControl: false,
		visibilityRatio: 1,
		constrainDuringPan: true,
		defaultZoomLevel: getCoverZoom(),
		minZoomLevel: getCoverZoom(),
	});

	viewer.addOnceHandler('open', function () {
		viewer.addHandler('resize', function () {
			const coverZoom = getCoverZoom();
			viewer.viewport.minZoomLevel = coverZoom;
			const current = viewer.viewport.getZoom();
			if (current < coverZoom) {
				viewer.viewport.zoomTo(coverZoom, null, true);
			}
		});
	});
</script>
