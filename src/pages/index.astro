---
import Layout from '../layouts/Layout.astro';
---

<Layout fullscreen={true}>
	<section class="hero">
		<picture class="hero-picture">
			<source srcset="/assets/hero2.avif" type="image/avif" />
			<img src="/assets/hero2.avif" alt="" class="hero-img" fetchpriority="high" decoding="async" />
		</picture>
	</section>
</Layout>

<style>
	.hero {
		width: 100vw;
		height: 100vh;
		overflow: hidden;
		position: relative;
	}

	.hero-picture {
		position: absolute;
		inset: 0;
	}

	.hero-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
	}
</style>
